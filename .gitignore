# -----------------------------
# Python bytecode
# -----------------------------
__pycache__/
*.py[cod]
*$py.class

# -----------------------------
# Virtual environments
# -----------------------------
venv/
.venv/
env/
ENV/

# -----------------------------
# Distribution / packaging
# -----------------------------
build/
dist/
*.egg-info/
.eggs/

# -----------------------------
# Jupyter notebooks
# -----------------------------
.ipynb_checkpoints/

# -----------------------------
# Logs
# -----------------------------
*.log

# -----------------------------
# Temporary files
# -----------------------------
*.tmp
*.temp
*.swp
*~

# -----------------------------
# IDEs and editors
# -----------------------------
.vscode/
.idea/

# -----------------------------
# OS files
# -----------------------------
.DS_Store
Thumbs.db

# -----------------------------
# Test / coverage
# -----------------------------
.coverage
htmlcov/
.pytest_cache/

# -----------------------------
# Python version manager
# -----------------------------
.python-version

# -----------------------------
# Compiled libraries
# -----------------------------
*.so
*.dylib

# -----------------------------
# Data files (optional)
# -----------------------------
data/outputs/*
!data/outputs/.gitkeep
data/pdb/*
!data/pdb/.gitkeep
